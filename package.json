{
  "private": true,
  "type": "module",
  "scripts": {
    "build": "esbuild src/inject.js --bundle --outfile=dist/inject.js --format=iife --target=es2020 --minify --legal-comments=none",
    "watch": "esbuild src/inject.js --bundle --outfile=dist/inject.js --format=iife --target=es2020 --watch",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "lint:ext": "npm run build && node scripts/prepare-ext.js && web-ext lint --source-dir=build-tmp",
    "lint:all": "npm run lint && npm run lint:ext"
  },
  "devDependencies": {
    "esbuild": "^0.25.0",
    "eslint": "^9.0.0",
    "@eslint/js": "^9.0.0",
    "web-ext": "^8.0.0"
  }
}
